generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  bio       String?
  avatarUrl String?
  isPublic  Boolean @default(true)

  mealEntries      MealEntry[]
  bodyMeasurements BodyMeasurement[]
  goals            UserGoals?
  workoutSessions   WorkoutSession[]
  workoutPlans      WorkoutPlan[]
  pushSubscriptions PushSubscription[]
  following  UserFollow[] @relation("Follower")
  followers  UserFollow[] @relation("Following")
}

model MealEntry {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      String
  mealType  String
  name      String
  calories  Float
  protein   Float
  carbs     Float
  fat       Float
  grams     Float
  timestamp BigInt

  @@index([userId, date])
}

model BodyMeasurement {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  date       String
  weight     Float
  height     Float?
  bodyFat    Float?
  muscleMass Float?
  waist      Float?
  chest      Float?
  leftArm    Float?
  rightArm   Float?
  notes      String?

  @@index([userId])
}

model UserGoals {
  id       String @id @default(cuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  calories Float @default(2000)
  protein  Float @default(100)
  carbs    Float @default(250)
  fat      Float @default(65)
}

model WorkoutSession {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  date        String
  exercises   String
  completedAt BigInt?
  notes       String?

  @@index([userId])
}

model WorkoutPlan {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  sessions  String  // JSON: WorkoutPlanSession[]
  createdAt BigInt
  isPublic  Boolean @default(false)

  sharedLinks SharedPlan[]

  @@index([userId])
}

model UserFollow {
  followerId  String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
}

model SharedPlan {
  id        String  @id @default(cuid())
  token     String  @unique
  planId    String?
  plan      WorkoutPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint  String   @unique
  p256dh    String
  auth      String

  createdAt DateTime @default(now())

  @@index([userId])
}
